<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.controller.CartController"
            stylesheets="@style.css"
            styleClass="cart-root">

    <!-- TOP BAR -->

    <top>

        <HBox alignment="CENTER_LEFT"
               spacing="15"
               styleClass="cart-topbar">

            <padding>
                <Insets top="15" right="25" bottom="15" left="25"/>
            </padding>

            <Button text="← Back"
                    onAction="#handleBackToStore"
                    styleClass="back-button"/>

            <Label text="Your Cart"
                   styleClass="cart-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="totalLabel"
                   text="Total: $0.00"
                   styleClass="cart-total"/>

        </HBox>

    </top>

    <!-- CENTER -->

    <center>

        <VBox spacing="20">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="cartTable"
                       styleClass="cart-table">

                <placeholder>
                    <VBox alignment="CENTER" spacing="10">

                        <Label text="🛒"
                               style="-fx-font-size: 42px;"/>

                        <Label text="Your cart is empty."
                               styleClass="empty-label"/>

                    </VBox>
                </placeholder>

                <columns>

                    <TableColumn fx:id="nameCol"
                                 text="Product"
                                 prefWidth="280"/>

                    <TableColumn fx:id="priceCol"
                                 text="Price"
                                 prefWidth="140"/>

                    <TableColumn fx:id="qtyCol"
                                 text="Quantity"
                                 prefWidth="120"/>

                    <TableColumn fx:id="subtotalCol"
                                 text="Subtotal"
                                 prefWidth="160"/>

                </columns>

            </TableView>

        </VBox>

    </center>

    <!-- BOTTOM -->

    <bottom>

        <HBox alignment="CENTER_RIGHT"
               spacing="15"
               styleClass="cart-bottom-bar">

            <padding>
                <Insets top="15" right="25" bottom="15" left="25"/>
            </padding>

            <Button text="Remove Selected"
                    onAction="#handleRemove"
                    styleClass="remove-button"/>

            <Button text="Checkout"
                    onAction="#handleCheckout"
                    styleClass="checkout-button"/>

        </HBox>

    </bottom>

</BorderPane>