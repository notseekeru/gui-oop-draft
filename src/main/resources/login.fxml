<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="main.controller.LoginController"
  stylesheets="@style.css">

  <HBox prefWidth="900"
    prefHeight="550"
    maxWidth="900"
    maxHeight="550"
    styleClass="main-container">

    <VBox prefWidth="380"
      alignment="CENTER_LEFT"
      spacing="20"
      styleClass="left-panel">

      <padding>
        <Insets top="40" right="40" bottom="40" left="40" />
      </padding>

      <Label text="Shop smart,&#10;Shop SHOPORA"
        wrapText="true"
        styleClass="left-title" />

      <Label text="Shapora: Everything you need, exactly when you need it."
        wrapText="true"
        styleClass="left-subtitle" />

    </VBox>

    <VBox prefWidth="520"
      alignment="CENTER"
      styleClass="right-panel">

      <VBox spacing="18"
        alignment="CENTER"
        maxWidth="320">

        <HBox alignment="CENTER" spacing="8">

          <Region styleClass="logo-dot" />

          <Label text="SHOPORA"
            styleClass="logo-text" />

        </HBox>

        <Label fx:id="modeLabel"
          text="Welcome Back"
          styleClass="main-title" />

        <Label text="Please login to your account"
          styleClass="subtitle" />

        <VBox spacing="12">

          <TextField fx:id="usernameField"
            promptText="Username"
            onAction="#handlePrimary"
            styleClass="input-field" />

          <PasswordField fx:id="passwordField"
            promptText="Password"
            onAction="#handlePrimary"
            styleClass="input-field" />

        </VBox>

        <Button fx:id="primaryBtn"
          text="Login"
          onAction="#handlePrimary"
          styleClass="login-button" />

        <HBox alignment="CENTER" spacing="5">

          <Label text="Don't have an account?"
            styleClass="register-text" />

          <Button fx:id="toggleBtn"
            text="Register"
            onAction="#handleToggle"
            styleClass="register-button" />

        </HBox>

      </VBox>

    </VBox>

  </HBox>

</StackPane>